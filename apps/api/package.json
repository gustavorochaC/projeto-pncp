{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prisma:generate": "node ../../scripts/ensure-prisma-client.mjs --force",
    "prisma:generate:raw": "prisma generate --schema prisma/schema.prisma",
    "predev": "node ../../scripts/ensure-prisma-client.mjs",
    "prebuild": "node ../../scripts/ensure-prisma-client.mjs",
    "dev": "env-cmd -f ../../.env node scripts/dev.mjs",
    "build": "nest build",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.0.6",
    "@nestjs/config": "^4.0.1",
    "@nestjs/core": "^11.0.6",
    "@nestjs/platform-express": "^11.0.6",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.0.3",
    "@pncp/types": "0.1.0",
    "@prisma/client": "^6.5.0",
    "bullmq": "^5.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.2",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.1",
    "@nestjs/testing": "^11.0.6",
    "@types/node": "^22.13.10",
    "@types/pdf-parse": "^1.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
